{
  "manifest_version": 2,
  "name": "Hush for Haiilo",
  "version": "1.0.0",
  "description": "Mute users on Haiilo - hide posts and comments from specific users",
  "permissions": [
    "storage",
    "contextMenus",
    "https://*.haiilo.app/*",
    "https://*.haiilo.com/*"
  ],
  "background": {
    "scripts": ["background-firefox.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.haiilo.app/*",
        "https://*.haiilo.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Hush for Haiilo"
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hush-for-haiilo@example.com",
      "strict_min_version": "109.0"
    }
  }
}
